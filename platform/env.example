# Copy to /etc/homedir.env and fill every placeholder. Do NOT commit secrets.

# Image registry and tag defaults
IMAGE_REPO=quay.io/sergio_canales_e/homedir
IMAGE_REPOSITORIES=quay.io/sergio_canales_e/homedir ghcr.io/os-santiago/homedir
# Optional fallback tag if you run homedir-update.service manually
# DEPLOY_TAG=v2.2.19
# Fallback polling deploy (recommended backup even with GitHub Actions SSH deploy)
AUTO_DEPLOY_ENABLED=true
AUTO_DEPLOY_TAG_LIMIT=100
AUTO_DEPLOY_TIMEOUT_SECONDS=15
AUTO_DEPLOY_LOGFILE=/var/log/homedir-auto-deploy.log
ALERT_SCRIPT=/usr/local/bin/homedir-discord-alert.sh
DISCORD_ALERTS_ENABLED=true
# Prefer *_FILE to avoid storing plaintext secrets in /etc/homedir.env.
# ALERTS_DISCORD_WEBHOOK_URL=__ALERTS_DISCORD_WEBHOOK_URL__
ALERTS_DISCORD_WEBHOOK_URL_FILE=/etc/homedir-secrets/ALERTS_DISCORD_WEBHOOK_URL
DISCORD_ALERTS_LOGFILE=/var/log/homedir-alerts.log
DISCORD_ALERTS_TIMEOUT_SECONDS=10
DISCORD_ALERTS_USERNAME=HomeDir Alerts
DISCORD_ALERTS_APP_NAME=HomeDir Deploy

# Container ports
HOST_PORT=8080
CONTAINER_PORT=8080

# Paths
LOGFILE=/var/log/homedir-update.log
DATA_VOLUME=/work/data:/work/data:Z
ENV_FILE=/etc/homedir.env

# Runtime limits (recommended baseline for ~400 concurrent users)
CONTAINER_MEMORY_LIMIT=2g
CONTAINER_CPU_LIMIT=3
CONTAINER_PIDS_LIMIT=2048

# Webhook hardening (recommended)
WEBHOOK_BIND_ADDRESS=127.0.0.1
WEBHOOK_REQUIRE_SIGNATURE=true
# WEBHOOK_SHARED_SECRET=__WEBHOOK_SHARED_SECRET__
# WEBHOOK_STATUS_TOKEN=__WEBHOOK_STATUS_TOKEN__
WEBHOOK_SHARED_SECRET_FILE=/etc/homedir-secrets/WEBHOOK_SHARED_SECRET
WEBHOOK_STATUS_TOKEN_FILE=/etc/homedir-secrets/WEBHOOK_STATUS_TOKEN
WEBHOOK_MAX_BODY_BYTES=1048576

# First-level incident response (DoS/traffic attack)
INCIDENT_LOCK_FILE=/etc/homedir.incident.lock
INCIDENT_LOG_DIR=/var/log/homedir-incident
INCIDENT_HEALTH_PATH=/q/health
INCIDENT_HEALTH_TIMEOUT_SECONDS=180

# CFP operational monitoring (429/5xx/timeouts)
CFP_MONITOR_ENABLED=true
CFP_MONITOR_WINDOW_MINUTES=5
CFP_MONITOR_LINES_PER_MINUTE=400
CFP_MONITOR_MIN_SAMPLE=30
CFP_MONITOR_MAX_ERROR_RATE_PERCENT=5
CFP_MONITOR_MAX_429_COUNT=20
CFP_MONITOR_MAX_TIMEOUT_COUNT=5
CFP_MONITOR_ACCESS_LOG=/var/log/nginx/access.log
CFP_MONITOR_ERROR_LOG=/var/log/nginx/error.log
CFP_MONITOR_LOGFILE=/var/log/homedir-cfp-monitor.log

# Application secrets (replace with real values)
# Data dir consumed by Quarkus config
HOMEDIR_DATA_DIR=/work/data
# Keep this JVM system property for components that still resolve data dir via System.getProperty.
JAVA_TOOL_OPTIONS=-Dhomedir.data.dir=/work/data
OIDC_CLIENT_ID=__OIDC_CLIENT_ID__
# OIDC_CLIENT_SECRET=__OIDC_CLIENT_SECRET__
OIDC_CLIENT_SECRET_FILE=/etc/homedir-secrets/OIDC_CLIENT_SECRET
GH_CLIENT_ID=__GH_CLIENT_ID__
# GH_CLIENT_SECRET=__GH_CLIENT_SECRET__
GH_CLIENT_SECRET_FILE=/etc/homedir-secrets/GH_CLIENT_SECRET
DISCORD_CLIENT_ID=__DISCORD_CLIENT_ID__
# DISCORD_CLIENT_SECRET=__DISCORD_CLIENT_SECRET__
DISCORD_CLIENT_SECRET_FILE=/etc/homedir-secrets/DISCORD_CLIENT_SECRET
# Required for secure Discord claim validation against guild membership
COMMUNITY_BOARD_DISCORD_GUILD_ID=__COMMUNITY_BOARD_DISCORD_GUILD_ID__
# SESSION_KEY=__SESSION_KEY__
# NOTIFICATIONS_USER_HASH_SALT=__NOTIFICATIONS_USER_HASH_SALT__
# GH_TOKEN=__GH_TOKEN__
SESSION_KEY_FILE=/etc/homedir-secrets/SESSION_KEY
NOTIFICATIONS_USER_HASH_SALT_FILE=/etc/homedir-secrets/NOTIFICATIONS_USER_HASH_SALT
GH_TOKEN_FILE=/etc/homedir-secrets/GH_TOKEN
# Optional if Discord board integration is enabled.
# COMMUNITY_BOARD_DISCORD_BOT_TOKEN=__COMMUNITY_BOARD_DISCORD_BOT_TOKEN__
COMMUNITY_BOARD_DISCORD_BOT_TOKEN_FILE=/etc/homedir-secrets/COMMUNITY_BOARD_DISCORD_BOT_TOKEN
APP_PUBLIC_URL=https://homedir.opensourcesantiago.io
QUARKUS_HTTP_PROXY_ALLOW_X_FORWARDED=true
QUARKUS_HTTP_PROXY_ALLOW_FORWARDED=false
QUARKUS_OIDC_AUTHENTICATION_FORCE_REDIRECT_HTTPS_SCHEME=true

# Logging
QUARKUS_LOG_LEVEL=INFO
QUARKUS_LOG_CATEGORY_IO_QUARKUS_QUTE_LEVEL=INFO
QUARKUS_LOG_CATEGORY_IO_QUARKUS_HTTP_LEVEL=INFO
QUARKUS_HTTP_ACCESS_LOG_ENABLED=true
QUARKUS_HTTP_ACCESS_LOG_OUTPUT=console
