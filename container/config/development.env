# ============================================================================
# HomeDir SDLC Pod - Development Environment Configuration
# ============================================================================

# GitHub Configuration
GH_TOKEN=<set-in-secrets>
HOMEDIR_SDLC_REPO=os-santiago/homedir

# Container Images (use local builds in development)
HOMEDIR_IMAGE=localhost/homedir:dev
HOMEDIR_SDLC_IMAGE=localhost/homedir-sdlc:dev

# Worker Configuration
SCC_PROFILE=nvidia
HOMEDIR_SDLC_MAX_ISSUES_PER_RUN=5
HOMEDIR_SDLC_ENABLE_AUTOMERGE=false
HOMEDIR_SDLC_SCC_TIMEOUT_SECONDS=900
HOMEDIR_SDLC_SCC_CLEAR_HISTORY=true

# Quarkus Configuration
QUARKUS_PROFILE=dev
