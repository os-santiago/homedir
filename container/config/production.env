# ============================================================================
# HomeDir SDLC Pod - Production Environment Configuration
# ============================================================================

# GitHub Configuration
GH_TOKEN=<set-in-secrets>
HOMEDIR_SDLC_REPO=os-santiago/homedir

# Container Images
HOMEDIR_IMAGE=ghcr.io/os-santiago/homedir:latest
HOMEDIR_SDLC_IMAGE=ghcr.io/os-santiago/homedir-sdlc:latest

# Worker Configuration
SCC_PROFILE=nvidia
HOMEDIR_SDLC_MAX_ISSUES_PER_RUN=1
HOMEDIR_SDLC_ENABLE_AUTOMERGE=false
HOMEDIR_SDLC_SCC_TIMEOUT_SECONDS=1800

# Quarkus Configuration
QUARKUS_PROFILE=prod
